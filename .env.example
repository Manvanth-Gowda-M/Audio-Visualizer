# ── Database ──────────────────────────────────────────────────────────────────
# SQLite for local dev. On Vercel use a persistent DB (e.g. Vercel Postgres / PlanetScale)
DATABASE_URL="file:./prisma/prisma/dev.db"

# ── Remotion Lambda (required for Vercel / production rendering) ───────────────
# 1. Run: npx remotion lambda policies user   → attach to your IAM user
# 2. Run: npx remotion lambda functions deploy --memory=2048 --disk=10240 --timeout=240
# 3. Run: npx remotion lambda sites create remotion/Root.tsx --site-name=audio-visualizer
#         → copy the "Serve URL" output into REMOTION_SERVE_URL below

REMOTION_AWS_ACCESS_KEY_ID=your_access_key_here
REMOTION_AWS_SECRET_ACCESS_KEY=your_secret_key_here
REMOTION_AWS_REGION=us-east-1
REMOTION_SERVE_URL=https://remotionlambda-xxxx.s3.us-east-1.amazonaws.com/sites/audio-visualizer/index.html

# Memory/disk/timeout must match what you deployed above
REMOTION_MEMORY_MB=2048
REMOTION_DISK_MB=10240
REMOTION_TIMEOUT_S=240

# ── App URL (used to build media URLs for Lambda to fetch) ────────────────────
# Set this to your Vercel deployment URL (without trailing slash)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Upload storage (optional — defaults to /tmp which is ephemeral on Vercel) ──
# For persistent uploads, point this to a mounted volume or use cloud storage
# UPLOAD_ROOT=/persistent/uploads
